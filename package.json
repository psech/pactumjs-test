{
  "name": "pactumjs-test",
  "version": "1.0.0",
  "description": "PactumJS learning project with a provider and consumer service",
  "scripts": {
    "start:provider": "node src/provider",
    "start:consumer": "node src/consumer",
    "start": "concurrently -n provider,consumer -c blue,green \"npm:start:provider\" \"npm:start:consumer\"",
    "test:api:provider": "node --test --import ./tests/api/provider/setup.ts 'tests/api/provider/**/*.test.ts'",
    "test:api:consumer": "node --test --import ./tests/api/consumer/setup.ts 'tests/api/consumer/**/*.test.ts'",
    "test:contract:consumer": "node --test --import ./tests/contract/consumer/setup.ts 'tests/contract/consumer/**/*.contract.ts'",
    "test:contract:provider": "node --test --import ./tests/contract/provider/setup.ts 'tests/contract/provider/**/*.flow.ts'",
    "test:integration": "node --test --import ./tests/integration/setup.ts 'tests/integration/**/*.test.ts'",
    "test:e2e": "node --test --import ./tests/e2e/setup.ts 'tests/e2e/**/*.e2e.ts'",
    "flow-server:up": "docker compose up -d",
    "flow-server:down": "docker compose down"
  },
  "dependencies": {
    "express": "^4.19.2",
    "pactum": "^3.7.6",
    "pactum-flow-plugin": "^0.1.4"
  },
  "devDependencies": {
    "@types/node": "^24.0.0",
    "concurrently": "^8.2.2",
    "get-port": "^7.2.0",
    "pactum-matchers": "^1.2.0"
  }
}
